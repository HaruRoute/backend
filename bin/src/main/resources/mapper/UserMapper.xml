<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chatbot.backend.domain.user.repository.UserRepository">

    <resultMap id="userResultMap" type="com.chatbot.backend.domain.user.entity.User">
        <id     property="id"   column="user_id"/>
        <result property="pw"   column="pw"/>
        <result property="name" column="name"/>
        <result property="role" column="role"/>
    </resultMap>

    <insert id="insert" parameterType="com.chatbot.backend.domain.user.entity.User">
        INSERT INTO users (user_id, pw, name, role)
        VALUES (#{id}, #{pw}, #{name}, #{role})
    </insert>

    <select id="findById" resultMap="userResultMap">
        SELECT user_id, pw, name, role
        FROM users
        WHERE user_id = #{id}
    </select>

    <select id="findByIdAndName" resultMap="userResultMap">
        SELECT user_id, pw, name, role
        FROM users
        WHERE user_id = #{id} AND name = #{name}
    </select>

    <select id="existsById" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM users
        WHERE user_id = #{id}
    </select>

    <select id="existsByRole" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM users
        WHERE role = #{role}
    </select>

    <update id="update" parameterType="com.chatbot.backend.domain.user.entity.User">
        UPDATE users
        <set>
            <if test="pw != null and pw != ''">pw = #{pw},</if>
            <if test="name != null and name != ''">name = #{name},</if>
        </set>
        WHERE user_id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM users WHERE user_id = #{id}
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chatbot.backend.domain.chat.repository.ChatHistoryRepository">

    <insert id="insert" parameterType="com.chatbot.backend.domain.chat.entity.ChatHistory"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_history (user_id, message, response, created_at)
        VALUES (#{userId}, #{message}, #{response}, #{createdAt})
    </insert>

    <select id="findByUserIdOrderByCreatedAtAsc"
            resultType="com.chatbot.backend.domain.chat.entity.ChatHistory">
        SELECT id, user_id, message, response, created_at
        FROM chat_history
        WHERE user_id = #{userId}
        ORDER BY created_at ASC
    </select>

    <delete id="deleteByUserId">
        DELETE FROM chat_history WHERE user_id = #{userId}
    </delete>

</mapper>
